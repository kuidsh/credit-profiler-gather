# ============================================================
# PLANTILLA DE VARIABLES DE ENTORNO
# ============================================================
# Copia este archivo como .env en la raíz del proyecto y
# completa los valores reales. Nunca subas .env al repositorio.
#
# Prisma CLI carga .env por defecto (no .env.local).
# Vite carga .env.local en desarrollo.
# Para dev local se recomienda usar .env con ambas variables.
# ============================================================

# DeepSeek API Key
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Base de datos local
# SQLite (dev sin Docker):
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL local con Docker:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/perfilador_dev"
# Aurora Serverless v2 (producción — configurar en AWS Amplify env vars):
# DATABASE_URL="postgresql://user:pass@cluster.us-east-1.rds.amazonaws.com:5432/perfilador_prod"
