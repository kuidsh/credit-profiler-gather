// prisma/schema.prisma
// Compatible con SQLite (dev) y PostgreSQL (prod/staging)
// Cambiar el provider en datasource según entorno via DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Cambiar a "sqlite" para dev local sin Docker
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// sesiones_wizard
// Tabla raíz. Cada ejecución completa del wizard (llegó al Paso 4) genera
// un registro aquí. Es el punto de entrada de ambas ramas de persistencia.
//
// Regla de persistencia:
//   guardarCompleto = clasificacionRecomendada IN ('Banco', 'Financiera')
//   Subprime        → solo interacción anonimizada, sin datos sensibles
//
// Guardado progresivo del Paso 5:
//   paso5ContactoGuardado → true cuando el usuario completa el sub-paso 1
//                           (Contacto). Se hace UPSERT en datos_personales_paso5
//                           vía POST /api/guardar-contacto
//   paso5Completado       → true cuando los 3 sub-pasos del Paso 5 son
//                           completados. Se actualiza vía PUT /api/guardar-perfil/:sesionId
// ---------------------------------------------------------------------------
model SesionWizard {
  id                       String   @id @default(uuid())
  sesionToken              String   @unique @db.VarChar(64)
  creadoEn                 DateTime @default(now())
  actualizadoEn            DateTime @updatedAt
  paso5ContactoGuardado    Boolean  @default(false) // true cuando sub-paso 1 (Contacto) es guardado
  paso5Completado          Boolean  @default(false) // true cuando los 3 sub-pasos del Paso 5 son completados
  guardarCompleto          Boolean  // true si clasificacion = Banco | Financiera
  clasificacionRecomendada String   @db.VarChar(20) // "Banco" | "Financiera" | "Subprime"
  viabilidadInicial        String   @db.VarChar(10) // "Alta" | "Media" | "Baja"
  cargaFinanciera          String   @db.VarChar(15) // "Cómoda" | "Justa" | "Apretada"
  fuentePersistencia       String   @db.VarChar(20) // "completa" | "anonima"

  // Relaciones
  perfilCompleto     PerfilCompleto?
  interaccionAnonima InteraccionAnonima?

  @@index([sesionToken])
  @@index([creadoEn])
  @@index([guardarCompleto])
  @@index([clasificacionRecomendada])
  @@map("sesiones_wizard")
}

// ---------------------------------------------------------------------------
// perfiles_completos
// Solo existe cuando guardarCompleto = true (Banco o Financiera).
// Contiene los 16 campos del wizard + resultado completo del LLM.
// ---------------------------------------------------------------------------
model PerfilCompleto {
  id            String   @id @default(uuid())
  sesionId      String   @unique
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  sesion SesionWizard @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  // ── Paso 1 — Datos del cliente ──────────────────────────────────────────
  ocupacion         String  @db.VarChar(30)
  antiguedad        Decimal @db.Decimal(5, 1)
  ingresoMensual    Decimal @db.Decimal(12, 2)
  compruebaIngresos String  @db.VarChar(10)
  tipoDomicilio     String  @db.VarChar(15)

  // ── Paso 2 — Perfil financiero ──────────────────────────────────────────
  historialCrediticio String  @db.VarChar(20)
  deudasMensuales     Decimal @db.Decimal(12, 2)
  rentaHipoteca       Decimal @db.Decimal(12, 2)
  numDependientes     Int

  // ── Paso 3 — Auto y operación ───────────────────────────────────────────
  precioAuto         Decimal @db.Decimal(12, 2)
  anioModelo         Int
  tipoUnidad         String  @db.VarChar(25)
  enganche           Decimal @db.Decimal(12, 2)
  mensualidadBuscada Decimal @db.Decimal(12, 2)
  plazoDeseado       Int
  aceptaAjustar      Boolean

  // ── Paso 4 — Resultado LLM ──────────────────────────────────────────────
  viabilidadInicial          String  @db.VarChar(10)
  clasificacionRecomendada   String  @db.VarChar(20)
  capacidadPago              String  @db.VarChar(10)
  cargaFinanciera            String  @db.VarChar(15)
  porQue                     String  @db.Text
  recomendacionesAccionables String  @db.Text
  fraseVendedor              String  @db.Text
  advertenciaComercial       String  @db.Text
  porcentajeCargaCalculado   Decimal @db.Decimal(5, 2)

  datosPersonales DatosPersonalesPaso5?

  @@index([sesionId])
  @@index([clasificacionRecomendada])
  @@index([ocupacion])
  @@index([creadoEn])
  @@map("perfiles_completos")
}

// ---------------------------------------------------------------------------
// datos_personales_paso5
// Solo existe cuando guardarCompleto = true Y el usuario ha completado al
// menos el sub-paso 1 (Contacto) del Paso 5.
// Contiene exclusivamente PII — acceso debe estar restringido en BD.
//
// Estrategia de guardado progresivo:
//   El registro se crea con UPSERT en cuanto el usuario completa el sub-paso 1.
//   Los campos de los sub-pasos 2 y 3 son opcionales (?) para tolerar abandonos.
//
// Endpoints:
//   POST /api/guardar-contacto
//     — Crea o actualiza (UPSERT por perfilId) con los datos del sub-paso 1.
//     — Marca sesiones_wizard.paso5ContactoGuardado = true.
//     — Establece subPasoCompletado = 1, completado = false.
//   PUT /api/guardar-perfil/:sesionId
//     — Actualiza el registro existente con los datos de sub-pasos 2 y 3.
//     — Marca sesiones_wizard.paso5Completado = true.
//     — Establece subPasoCompletado = 3, completado = true.
//
// subPasoCompletado: 1 = solo Contacto guardado
//                    2 = Contacto + Identificación guardados
//                    3 = los 3 sub-pasos completos
// ---------------------------------------------------------------------------
model DatosPersonalesPaso5 {
  id            String   @id @default(uuid())
  perfilId      String   @unique
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  perfil PerfilCompleto @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  // ── Control de progreso ──────────────────────────────────────────────────
  subPasoCompletado Int     @default(1) // 1 | 2 | 3 — último sub-paso guardado exitosamente
  completado        Boolean @default(false) // true solo cuando los 3 sub-pasos están completos

  // ── Sub-paso 1: Contacto (NOT NULL — siempre se guardan primero) ─────────
  nombres         String @db.VarChar(100)
  apellidoPaterno String @db.VarChar(60)
  apellidoMaterno String? @db.VarChar(60) // opcional
  telefonoCelular String @db.VarChar(15)

  // ── Sub-paso 2: Identificación (opcionales — el usuario podría abandonar) ─
  fechaNacimiento DateTime? @db.Date
  rfc             String?   @db.VarChar(13)
  curp            String?   @db.VarChar(18)
  genero          String?   @db.VarChar(20)
  estadoCivil     String?   @db.VarChar(20)
  correoElectronico   String? @db.VarChar(150)
  telefonoCasaTrabajo String? @db.VarChar(15) // teléfono alternativo

  // ── Sub-paso 3: Domicilio (opcionales — el usuario podría abandonar) ─────
  calle               String? @db.VarChar(150)
  numeroExterior      String? @db.VarChar(20)
  numeroInterior      String? @db.VarChar(20)
  colonia             String? @db.VarChar(100)
  municipioDelegacion String? @db.VarChar(100)
  estadoRepublica     String? @db.VarChar(50)
  codigoPostal        String? @db.VarChar(5)
  tipoDomicilioPaso5  String? @db.VarChar(15)
  tiempoEnDomicilio   String? @db.VarChar(30)

  @@index([perfilId])
  @@index([telefonoCelular])
  @@index([rfc])
  @@index([correoElectronico])
  @@index([completado])
  @@map("datos_personales_paso5")
}

// ---------------------------------------------------------------------------
// interacciones_anonimas
// Solo existe cuando guardarCompleto = false (Subprime).
// Sin PII, sin datos financieros exactos. Solo información categórica.
// ---------------------------------------------------------------------------
model InteraccionAnonima {
  id       String   @id @default(uuid())
  sesionId String   @unique
  creadoEn DateTime @default(now())

  sesion SesionWizard @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  // ── Campos categóricos del wizard (no sensibles) ────────────────────────
  ocupacion           String  @db.VarChar(30)
  rangosAntiguedad    String  @db.VarChar(20) // "0-1 años" | "1-3 años" | "3-5 años" | "5+ años"
  compruebaIngresos   String  @db.VarChar(10)
  tipoDomicilio       String  @db.VarChar(15)
  historialCrediticio String  @db.VarChar(20)
  numDependientes     Int
  anioModelo          Int
  tipoUnidad          String  @db.VarChar(25)
  plazoDeseado        Int
  aceptaAjustar       Boolean

  // ── Rangos calculados (nunca valores exactos) ───────────────────────────
  rangoIngresos String @db.VarChar(20) // "<15k" | "15k-25k" | "25k-40k" | "40k-60k" | "60k+"
  rangoEnganche String @db.VarChar(20) // "<10%" | "10-20%" | "20-30%" | "30%+"

  // ── Resultado LLM ───────────────────────────────────────────────────────
  viabilidadInicial        String @db.VarChar(10)
  clasificacionRecomendada String @db.VarChar(20) // siempre "Subprime" en esta tabla
  capacidadPago            String @db.VarChar(10)
  cargaFinanciera          String @db.VarChar(15)

  @@index([sesionId])
  @@index([creadoEn])
  @@index([ocupacion])
  @@index([clasificacionRecomendada])
  @@map("interacciones_anonimas")
}
